# ── Genessence frontend (Vite) environment variables ───────────────────────
# Copy to `.env` for local dev. In production (Render Static Site), set VITE_API_URL
# in the service's Environment. Vite inlines this at BUILD time, so a redeploy is
# required after changing it.

# Base URL of the backend API, INCLUDING the /api suffix.
#   Local dev:   http://localhost:5050/api
#   Production:  https://genessenceos.onrender.com/api
VITE_API_URL=http://localhost:5050/api
