# ── Genessence backend environment variables ───────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.

# PostgreSQL connection string (Prisma). REQUIRED.
#   Local dev:   postgresql://USER@localhost:5432/genessence?schema=public
#   Production:  use the Render PostgreSQL "Internal Database URL".
DATABASE_URL=postgresql://USER@localhost:5432/genessence?schema=public

# JWT signing secret. REQUIRED — the server refuses to start if unset.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-secret

# Allowed browser origin(s) for CORS. REQUIRED IN PRODUCTION (otherwise all
# cross-origin requests are blocked). Comma-separate multiple origins. No trailing slash.
#   Production: https://genessenceos-1.onrender.com
FRONTEND_URL=https://genessenceos-1.onrender.com

# HTTP port. Optional locally (defaults to 5050). On Render, leave UNSET —
# Render injects PORT and the app binds process.env.PORT automatically.
PORT=5050

# Environment. Set to "production" on Render; leave unset/development locally.
# NODE_ENV=production

# Directory for uploaded document files (local disk). NOTE: Render's filesystem is
# ephemeral — uploads do not survive restarts/redeploys. See README for the
# recommended object-storage migration (Cloudinary/S3/R2).
UPLOAD_DIR=uploads

# First-run seeding control. In production, seeding is OFF unless this is "true".
# Set to "true" for the FIRST deploy (creates admin/manager/viewer in an empty DB),
# then set back to "false".
# SEED_DATABASE=false
